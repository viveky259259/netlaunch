rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Uploads directory - authenticated users can upload to their own folder
    match /uploads/{userId}/{allPaths=**} {
      // Allow authenticated users to upload zip files to their own folder
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024 
                   && (request.resource.contentType == 'application/zip' 
                       || request.resource.contentType == 'application/x-zip-compressed'
                       || request.resource.contentType == 'application/octet-stream');
      allow read: if false; // Only Cloud Functions can read
      allow delete: if false; // Only Cloud Functions can delete
    }
    
    // Deployments directory - only Cloud Functions can access
    match /deployments/{allPaths=**} {
      allow read, write: if false; // Only Cloud Functions
    }
  }
}
