rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // API Keys collection - only Cloud Functions can write, no direct client access
    match /apiKeys/{apiKeyId} {
      allow read: if false; // No direct client reads
      allow write: if false; // Only Cloud Functions can write
    }
    
    // User Preferences - users can read/write their own preferences
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // File Upload Requests - authenticated users can create their own requests
    match /fileUploadRequests/{requestId} {
      // Allow authenticated users to create upload requests
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // Only Cloud Functions can read/update/delete
      allow read, update, delete: if false;
    }
    
    // Deployments collection - users can read their own deployments via API key
    match /deployments/{deploymentId} {
      // Allow read if the deployment's apiKey matches (this will be enforced in Cloud Functions)
      // For now, we'll restrict all client access and handle via Cloud Functions
      allow read: if false; // Read via Cloud Functions only for security
      allow write: if false; // Write via Cloud Functions only
    }

    // Page view analytics — server-only access via Cloud Functions
    match /pageViews/{siteId} {
      allow read, write: if false;
      match /{subcollection=**} {
        allow read, write: if false;
      }
    }
  }
}
