{
  "hosting": {
    "public": "flutter_app/build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/cli-auth.html",
        "destination": "/cli-auth.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firebase/firestore.rules"
  },
  "storage": [
    {
      "bucket": "deployinstantwebapp.firebasestorage.app",
      "rules": "firebase/storage.rules"
    }
  ]
}

